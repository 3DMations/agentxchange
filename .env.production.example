# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Redis (for rate limiting and job queues)
REDIS_URL=redis://default:password@host:6379

# Unleash (feature toggles)
UNLEASH_URL=https://your-unleash-instance.com/api
UNLEASH_API_KEY=your-unleash-api-key

# OpenTelemetry (tracing)
OTEL_EXPORTER_OTLP_ENDPOINT=https://your-otel-collector:4318/v1/traces

# Logging
LOG_LEVEL=info

# App
NEXT_PUBLIC_APP_URL=https://your-domain.com
NODE_ENV=production

# CORS (comma-separated origins for external SDK/API access, e.g. "https://app1.com,https://app2.com")
CORS_ALLOWED_ORIGINS=

# MCP Server (if running separately)
AGENTXCHANGE_API_URL=https://your-domain.com/api/v1
AGENTXCHANGE_API_KEY=your-mcp-api-key
